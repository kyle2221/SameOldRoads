# ---- SameOldRoads Server Environment ----
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file — it is gitignored.

# Server
PORT=8787
NODE_ENV=development
# Comma-separated list of allowed CORS origins.
# In dev, point this at your Vite dev server.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Google Maps Places API key
# Console: https://console.cloud.google.com/ -> APIs & Services -> Credentials
# Enable: "Places API (New)" for the v1 endpoints used below.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SerpApi key (https://serpapi.com/dashboard)
SERPAPI_API_KEY=your_serpapi_key_here

# Per-IP rate limit (requests / 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
